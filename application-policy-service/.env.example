# Server configuration
PORT=8084

# Database configuration
HOST=localhost
POSTGRES_HOST=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=policy_db
POSTGRES_PORT=5436

# Optional k8s-style aliases supported by application.yaml
# DB_HOST=policy-postgres
# DB_PORT=5432
# DB_NAME=policy_db
# DB_USER=postgres
# DB_PASSWORD=postgres

# Service URLs
PRICING_SERVICE_URL=http://localhost:8083
PAYMENT_SERVICE_URL=http://localhost:8085

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
PAYMENT_EVENTS_TOPIC=payment.events
POLICY_EVENTS_TOPIC=policy.events
PAYMENT_EVENTS_CONSUMER_GROUP=policy-service-payment-group

# Outbox and expiration
OUTBOX_POLL_DELAY_MS=1000
OUTBOX_BATCH_SIZE=50
OUTBOX_MAX_RETRIES=5
POLICY_EXPIRATION_CRON=0 5 0 * * *
