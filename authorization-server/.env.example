# Server configuration
PORT=9000
HOST=localhost

# Issuer URI
ISSUER_URI=http://localhost:9000

# Client Application config
CLIENT_APP_URI=http://localhost:3000
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000

# System OAuth2 Client config
CLIENT_ID=insu-client
CLIENT_SECRET=insu-secret-key
REDIRECT_URI=http://localhost:3000/login/oauth2/code/custom

# Database configuration
POSTGRES_HOST=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=auth_db
POSTGRES_PORT=5433

# Optional k8s-style aliases supported by application.yaml
# DB_HOST=auth-postgres
# DB_PORT=5432
# DB_NAME=auth_db
# DB_USER=postgres
# DB_PASSWORD=postgres

# Google login config
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_PATH=/login/oauth2/code/google

# User Service endpoint
USER_SERVICE_URI=http://localhost:8081
