# Server config
PORT=8080
HOST=localhost

# Redis Config
REDIS_HOST=localhost
REDIS_PASSWORD=secret_password
REDIS_PORT=6379

# OAuth2 Security
INSURANCE_AS_URI=http://localhost:7070
INSURANCE_AS_JWK_URI=http://localhost:7070/oauth2/jwks
GOOGLE_AS_URI=https://accounts.google.com
GOOGLE_AS_JWK_URI=https://www.googleapis.com/oauth2/v3/certs

# CORS
APP_CORS_ALLOWED_ORIGINS=*

# Downstream services
PRICING_SERVICE_URL=http://localhost:8083
POLICY_SERVICE_URL=http://localhost:8084
PAYMENT_SERVICE_URL=http://localhost:8085

# Optional rate limit
USER_PROFILE_UPDATE_RATE_LIMIT_ENABLED=true
USER_PROFILE_UPDATE_RATE_LIMIT_MAX_REQUESTS=5
USER_PROFILE_UPDATE_RATE_LIMIT_WINDOW=1m

# Eureka
EUREKA_SERVER_URL=http://localhost:8761/eureka/
