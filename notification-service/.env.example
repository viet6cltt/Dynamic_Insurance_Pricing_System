# Database configuration
PORT=8086
HOST=localhost
POSTGRES_HOST=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=notification_db
POSTGRES_PORT=5438

# Optional k8s-style aliases supported by application.yaml
# DB_HOST=notification-postgres
# DB_PORT=5432
# DB_NAME=notification_db
# DB_USER=postgres
# DB_PASSWORD=postgres

# Services URLs
USER_SERVICE_URL=http://localhost:8081

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
PAYMENT_EVENTS_TOPIC=payment.events
POLICY_EVENTS_TOPIC=policy.events
PRICING_EVENTS_TOPIC=pricing.events
NOTIFICATION_EVENTS_CONSUMER_GROUP=notification-service-group

# Email SMTP
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SMTP_AUTH=false
MAIL_SMTP_STARTTLS_ENABLE=false
MAIL_FROM=no-reply@insurance.local
MAIL_FROM_NAME=Dynamic Insurance

# Email outbox
EMAIL_OUTBOX_POLL_DELAY_MS=1000
EMAIL_OUTBOX_BATCH_SIZE=25
EMAIL_OUTBOX_MAX_RETRIES=5

# Eureka
EUREKA_SERVER_URL=http://localhost:8761/eureka/
