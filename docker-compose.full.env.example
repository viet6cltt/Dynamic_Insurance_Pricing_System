# Optional values consumed by docker-compose.full.yml.
# Copy to .env at the repository root if you want to override defaults.

IMAGE_TAG=local

# Auth / OAuth
ISSUER_URI=http://localhost:9000
CLIENT_ID=insu-client
CLIENT_SECRET=insu-secret-key
REDIRECT_URI=http://localhost:3000/login/oauth2/code/custom
CLIENT_APP_URI=http://localhost:3000
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_PATH=/login/oauth2/code/google

# Redis
REDIS_PASSWORD=secret_password

# Notification email.
# Default compose uses local Mailpit: SMTP localhost:1025, UI http://localhost:8025.
# For real SMTP, set these values and keep the same compose file.
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SMTP_AUTH=false
MAIL_SMTP_STARTTLS_ENABLE=false
MAIL_FROM=no-reply@insurance.local
MAIL_FROM_NAME=Dynamic Insurance

# AI model service
MODEL_SOURCE=auto
MLFLOW_TRACKING_URI=http://mlflow-server:5000
MLFLOW_TRACKING_PORT=15000
MLFLOW_POSTGRES_PORT=5439
MLFLOW_POSTGRES_DB=mlflow
MLFLOW_POSTGRES_USER=mlflow
MLFLOW_POSTGRES_PASSWORD=mlflow
MLFLOW_S3_BUCKET=mlflow-artifacts
MLFLOW_S3_ACCESS_KEY_ID=minioadmin
MLFLOW_S3_SECRET_ACCESS_KEY=minioadminpassword

# Policy notifications
CONTRACT_EXPIRY_REMINDER_DAYS=7
